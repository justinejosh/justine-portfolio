generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id             Int             @id @default(autoincrement())
  slug           String          @unique
  fullName       String
  preferredName  String
  headline       String
  age            Int
  school         String
  degreeProgram  String
  bio            String
  summary        String
  learningFocus  String
  focusAreas     String[]
  gpa            String?
  photoUrl       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  certifications Certification[]
  documents      Document[]
  experiences    Experience[]
  skills         Skill[]
}

model Certification {
  id            Int      @id @default(autoincrement())
  profileId     Int
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title         String
  issuer        String
  status        String
  issuedAt      DateTime?
  description   String
  credentialUrl String?
  displayOrder  Int      @default(0)
}

model Experience {
  id           Int                   @id @default(autoincrement())
  profileId    Int
  profile      Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title        String
  organization String
  period       String
  category     String
  summary      String
  displayOrder Int                   @default(0)
  highlights   ExperienceHighlight[]
}

model ExperienceHighlight {
  id           Int        @id @default(autoincrement())
  experienceId Int
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  text         String
  displayOrder Int        @default(0)
}

model Document {
  id           Int      @id @default(autoincrement())
  profileId    Int
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title        String
  type         String
  description  String
  fileUrl      String?
  buttonLabel  String
  isAvailable  Boolean  @default(false)
  displayOrder Int      @default(0)
}

model Skill {
  id           Int      @id @default(autoincrement())
  profileId    Int
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name         String
  category     String
  level        String
  logoKey      String
  description  String
  displayOrder Int      @default(0)
}
