# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
Desktop.ini
*.pem
AGENTS.md
CLAUDE.md
README.md
*.bak
*.backup
*.tmp
*.temp
*.orig
*.local

# editors / local workspace files
.vscode/
.idea/
*.code-workspace

